# --general--
# HPERSIST_ENV=dev                           # dev | prod | test
# HPERSIST_DATA_DIR=./data                   # logs, archives, uploads, SQLite

# --server--
# HPERSIST_SERVER__HOST=127.0.0.1
# HPERSIST_SERVER__PORT=8765
# HPERSIST_SERVER__LOG_LEVEL=info            # critical|error|warning|info|debug|trace
# HPERSIST_SERVER__RELOAD=false

# --database--
# HPERSIST_DB__URL=sqlite:///./data/hpersist.db 
# HPERSIST_DB__URL=postgresql+psycopg://user:pass@host:5432/hpersist       # Postgres example
# HPERSIST_DB__POOL_SIZE=5
# HPERSIST_DB__MAX_OVERFLOW=10
# HPERSIST_DB__POOL_TIMEOUT_SECONDS=30
# HPERSIST_DB__POOL_RECYCLE_SECONDS=1800
# HPERSIST_DB__ECHO=false                    # log every SQL statement

# --sqlite only--
# HPERSIST_DB__SQLITE_JOURNAL_MODE=WAL       # WAL|DELETE|TRUNCATE|PERSIST|MEMORY|OFF
# HPERSIST_DB__SQLITE_SYNCHRONOUS=NORMAL     # OFF|NORMAL|FULL|EXTRA
# HPERSIST_DB__SQLITE_BUSY_TIMEOUT_MS=15000
# HPERSIST_DB__SQLITE_FOREIGN_KEYS=true

# --collector--
# HPERSIST_COLLECTOR__CONCURRENCY=16
# HPERSIST_COLLECTOR__TIMEOUT_SECONDS=8.0
# HPERSIST_COLLECTOR__TLS_VERIFY=warn-only   # strict | warn-only | off

# --logging--
# HPERSIST_LOG__LEVEL=INFO                   # CRITICAL|ERROR|WARNING|INFO|DEBUG
# HPERSIST_LOG__RETENTION_DAYS=90

# --cors--
# HPERSIST_CORS__ALLOW_ORIGINS=["*"]
# HPERSIST_CORS__ALLOW_CREDENTIALS=false
# HPERSIST_CORS__ALLOW_METHODS=["*"]
# HPERSIST_CORS__ALLOW_HEADERS=["*"]
